# BIGWIGs

# chrX only
rule bigwig_bpm_X:
    input:
        bam=WORKDIR+"bam/merged_downsampled_bam/{cell_type}_{target_mark}_downsampled.bam",
        bai=WORKDIR+"bam/merged_downsampled_bam/{cell_type}_{target_mark}_downsampled.bam.bai"
    output: 
        WORKDIR+"bigwig/bpm/downsampled/{cell_type}_{target_mark}_downsampled.bpm.chrX.bw"
    params:
        normalization_method="BPM",
        binSize=20,
        smoothLength=40
    log: 
        "log/{cell_type}_{target_mark}_bpm-bw-chrX.log"
    shell:
        """
        bamCoverage -b {input.bam} --normalizeUsing {params.normalization_method} --binSize {params.binSize} --smoothLength {params.smoothLength} --region chrX -o {output} 2> {log}
        """


rule bigwig_igg_bpm_X:
    input:
        bam=WORKDIR+"bam/merged_downsampled_bam/{cell_type}_IGG.merged.bam",
        bai=WORKDIR+"bam/merged_downsampled_bam/{cell_type}_IGG.merged.bam.bai",
    output: 
        WORKDIR+"bigwig/bpm/downsampled/{cell_type}_IGG.merged.bpm.chrX.bw"
    params:
        normalization_method="BPM",
        binSize=20,
        smoothLength=40
    log: 
        "log/{cell_type}_IGG_bpm-bw-chrX.log"
    shell:
        """
        bamCoverage -b {input.bam} --normalizeUsing {params.normalization_method} --binSize {params.binSize} --smoothLength {params.smoothLength} --region chrX -o {output} 2> {log}
        """


rule bw_igg_norm_chrX:
    input:
        target=WORKDIR+"bigwig/bpm/downsampled/{cell_type}_{target_mark}_downsampled.bpm.chrX.bw",
        igg=WORKDIR+"bigwig/bpm/downsampled/{cell_type}_IGG.merged.bpm.chrX.bw"
    output:
        bw_log2ratioigg=WORKDIR+"bigwig/log2ratioigg/downsampled/{cell_type}_{target_mark}_downsampled.log2ratioigg.chrX.bw"
    log:
        err="log/{cell_type}_{target_mark}_bw_downsampled_log2igg.err"
    shell:
        """
        bigwigCompare -b1 {input.target} -b2 {input.igg} \\
        --operation log2 \\
        --outFileName {output.bw_log2ratioigg} \\
        --outFileFormat bigwig
        2> {log.err}
        """


