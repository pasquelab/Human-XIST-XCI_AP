        err="log/{cell_type}_{target_mark}_bw_downsampled_log2igg_allchr.err"
    shell:
        """
        bigwigCompare -b1 {input.target} -b2 {input.igg} \\
        --operation log2 \\
        --outFileName {output.bw_log2ratioigg} \\
        --outFileFormat bigwig
        2> {log.err}
        """



# MACS2

rule macs2:
    input:
        bam=WORKDIR+"bam/merged_downsampled_bam/{cell_type}_{target_mark}_downsampled.bam",
        bai=WORKDIR+"bam/merged_downsampled_bam/{cell_type}_{target_mark}_downsampled.bam.bai"
    output:
        peaks=WORKDIR+"macs2/{cell_type}_{target_mark}_macs2_peaks.broadPeak",
        gapped_peaks=WORKDIR+"macs2/{cell_type}_{target_mark}_macs2_peaks.gappedPeak",
        xls=WORKDIR+"macs2/{cell_type}_{target_mark}_macs2_peaks.xls"
    params:
        out_dir=WORKDIR+"macs2/",
        broad_cutoff=0.1
    log:
        "log/{cell_type}_{target_mark}_macs2.log"
    shell:
        "(macs2 callpeak \
            -t {input.bam} \
            -f BAMPE \
            -g 2913022398 \
            -n {wildcards.cell_type}_{wildcards.target_mark}_macs2 \
            --outdir {params.out_dir} \
            --keep-dup 'all' \
            --broad \
            --broad-cutoff {params.broad_cutoff} \
            --nolambda) \
            2> {log}" 

#genome effecive size (-g) from deeptools : https://deeptools.readthedocs.io/en/develop/content/feature/effectiveGenomeSize.html 


rule enlarging_peaks:
    input:
        peaks=WORKDIR+"macs2/{cell_type}_{target_mark}_macs2_peaks.broadPeak"
    output:
        enlarged_peaks=WORKDIR+"macs2/{cell_type}_{target_mark}_macs2_enlarged.bed"
    params:
        distance=10000
    shell:
        """
        bedtools merge -i {input.peaks} -d {params.distance} > {output.enlarged_peaks}
        """



# MPILEUP

rule AddOrReplaceReadGroups:
    input:
        bam=WORKDIR+"bam/merged_downsampled_bam/{sample}_downsampled.bam",
        bai=WORKDIR+"bam/merged_downsampled_bam/{sample}_downsampled.bam.bai"
    output: 
        temp(WORKDIR+"allelic_analysis/bam/downsampled/{sample}.wreadgp.bam")
    params:
        SO="coordinate",
        RGID="{sample}",
        RGLB="library",
        RGPL="platform",
        RGPU="machine",
        RGSM="RG:Z:{sample}"
    log:
        "log/{sample}_AddOrReplaceReadGroups.dwnspld.log"
    shell:
        "(picard  AddOrReplaceReadGroups \
            I={input.bam} \
            O={output} \
            SO={params.SO} \
            RGID={params.RGID} \
            RGLB={params.RGLB} \
            RGPL={params.RGPL} \
            RGPU={params.RGPU} \
            RGSM={params.RGSM}) 2> {log}"


rule AddOrReplaceReadGroups_IGG:
    input:
        bam=WORKDIR+"bam/merged_downsampled_bam/{sample}.merged.bam",
        bai=WORKDIR+"bam/merged_downsampled_bam/{sample}.merged.bam.bai"
    output: 
        temp(WORKDIR+"allelic_analysis/bam/downsampled/{sample}.wreadgp.bam")
    params:
        SO="coordinate",
        RGID="{sample}",
        RGLB="library",
        RGPL="platform",
        RGPU="machine",
        RGSM="RG:Z:{sample}"
    log:
        "log/{sample}_AddOrReplaceReadGroups.dwnspld.log"
    shell:
        "(picard  AddOrReplaceReadGroups \
            I={input.bam} \
            O={output} \
            SO={params.SO} \
            RGID={params.RGID} \
            RGLB={params.RGLB} \
            RGPL={params.RGPL} \
            RGPU={params.RGPU} \
            RGSM={params.RGSM}) 2> {log}"


rule index_bai:
    input: 
        bam=WORKDIR+"allelic_analysis/bam/downsampled/{sample}.wreadgp.bam"
    output: 
        temp(WORKDIR+"allelic_analysis/bam/downsampled/{sample}.wreadgp.bam.bai")
    shell:
        """
        samtools index {input.bam}
        """


rule SplitNCigarReads:
    input:
        bam=WORKDIR+"allelic_analysis/bam/downsampled/{sample}.wreadgp.bam",
        bai=WORKDIR+"allelic_analysis/bam/downsampled/{sample}.wreadgp.bam.bai"
    output:
        temp(WORKDIR+"allelic_analysis/bam/downsampled/{sample}_wreadgp_Nsplit.bam")
    params:
        ref=config["REF_HG38_FASTA"]
    log:
        "log/{sample}_SplitNCigarReads.dwnspld.log"
    shell:
        "(gatk SplitNCigarReads \
            -R {params.ref} \
            -I {input.bam} \
            -O {output}) 2> {log}"
# SplitNCigarReads also requires hg38.fai and hg38.dict


rule index_bai_split:
    input: 
        bam=WORKDIR+"allelic_analysis/bam/downsampled/{sample}_wreadgp_Nsplit.bam"
    output: 
        temp(WORKDIR+"allelic_analysis/bam/downsampled/{sample}_wreadgp_Nsplit.bam.bai")
    shell:
        """
        samtools index {input.bam}
        """


rule index_csi_split:
    input: 
        bam=WORKDIR+"allelic_analysis/bam/downsampled/{sample}_wreadgp_Nsplit.bam"
    output: 
        temp(WORKDIR+"allelic_analysis/bam/downsampled/{sample}_wreadgp_Nsplit.bam.csi")
    shell:
        """
        samtools index -c {input.bam}
        """



rule mpileup_samtools_chrX:
    input:
        bam=WORKDIR+"allelic_analysis/bam/downsampled/{sample}_wreadgp_Nsplit.bam",
        bai=WORKDIR+"allelic_analysis/bam/downsampled/{sample}_wreadgp_Nsplit.bam.bai",
        csi=WORKDIR+"allelic_analysis/bam/downsampled/{sample}_wreadgp_Nsplit.bam.csi"
    output:
        WORKDIR+"allelic_analysis/samtools_pileup/downsampled/{sample}_heteroz_SNP_chrX_samtools.dwnspld.pileup"
    params:
        ref=config["REF_HG38_FASTA"],
        pos_of_interest=config["POS_OF_INTEREST_X"]
    log: 
        "log/{sample}_samtools_mpileup_chrX.dwnspld.log"
    shell:
        """
        samtools mpileup --fasta-ref {params.ref} --positions {params.pos_of_interest} -a --output-MQ --no-output-ins --no-output-ins --no-output-del --no-output-del --no-output-ends --output {output} {input.bam} 2> {log}
        """


rule mpileup_samtools_chr7:
    input:
        bam=WORKDIR+"allelic_analysis/bam/downsampled/{sample}_wreadgp_Nsplit.bam",
        bai=WORKDIR+"allelic_analysis/bam/downsampled/{sample}_wreadgp_Nsplit.bam.bai",
