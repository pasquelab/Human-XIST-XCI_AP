# Downsampling bam files that were merged (replicates merged) 
## 22/02/2024 Jeanne 

configfile: "config.json"

WORKDIR = config["WORKING_PATH"]

rule all:
    input:
        # bigwigs
        bw_raw_allchr=expand(WORKDIR+"bigwig/raw/downsampled/{cell_type}_{target_mark}_downsampled.raw.bw", cell_type=config["CELL_TYPE"], target_mark=config["TARGET_MARK"]),
        bw_log2ratioigg_chrX=expand(WORKDIR+"bigwig/log2ratioigg/downsampled/{cell_type}_{target_mark}_downsampled.log2ratioigg.chrX.bw", cell_type=config["CELL_TYPE"], target_mark=config["TARGET_MARK"]),
        bw_log2ratioigg_allchr=expand(WORKDIR+"bigwig/log2ratioigg/downsampled/{cell_type}_{target_mark}_downsampled.log2ratioigg.bw", cell_type=config["CELL_TYPE"], target_mark=config["TARGET_MARK"]),
        # bam stats
        idxstats=expand(WORKDIR+"idxstats/{cell_type}_{target_mark}_downsampled.idxstats.txt", cell_type=config["CELL_TYPE"], target_mark=config["TARGET_MARK"]),
        # macs2 peaks enlarged
        enlarged_peaks=expand(WORKDIR+"macs2/{cell_type}_{target_mark}_macs2_enlarged.bed", cell_type=config["CELL_TYPE"], target_mark=config["TARGET_MARK"]),
        # mpileup for allelic analysis
        mpileup_chrX=expand(WORKDIR+"allelic_analysis/samtools_pileup/downsampled/{sample}_heteroz_SNP_chrX_samtools.dwnspld.pileup", sample=config["SAMPLES"]),
        mpileup_chr7=expand(WORKDIR+"allelic_analysis/samtools_pileup/downsampled/{sample}_heteroz_SNP_chr7_samtools.dwnspld.pileup", sample=config["SAMPLES"])



# DOWNSAMPLING

rule index_merged_PXGL:
    input:
        bam=WORKDIR+"bam/merged_downsampled_bam/PXGL_{mark}_Filtered.merged.bam"
    output:
        bai=WORKDIR+"bam/merged_downsampled_bam/PXGL_{mark}_Filtered.merged.bam.bai"
    threads: 4
    shell:
        """
        samtools index -@ {threads} {input.bam}
        """


rule index_merged_TSC_EXMC_primed:
    input:
        bam=WORKDIR+"bam/merged_downsampled_bam/{sample}.hg38.dedupped.merged.bam",
    output:
        bai=WORKDIR+"bam/merged_downsampled_bam/{sample}.hg38.dedupped.merged.bam.bai"
    threads: 4
    shell:
        """
        samtools index -@ {threads} {input.bam}
        """


rule bam_downsampling_PXGL:
    input:
        bam=WORKDIR+"bam/merged_downsampled_bam/PXGL_{target_mark}_Filtered.merged.bam",
        bai=WORKDIR+"bam/merged_downsampled_bam/PXGL_{target_mark}_Filtered.merged.bam.bai"
    output:
        bam_downsampled=WORKDIR+"bam/merged_downsampled_bam/PXGL_{target_mark}_downsampled.bam"
    log:
        "log/PXGL_{target_mark}_downsampling.log"
    threads: 6
    shell:
        """
        reads=26500000
        bam={input.bam}
        fraction=$(samtools idxstats -@ {threads} $bam | cut -f3 | awk -v ct=$reads 'BEGIN {{total=0}} {{total += $1}} END {{print ct/total}}')
        samtools view -@ {threads} -b -s ${{fraction}} $bam > {output.bam_downsampled} 2> {log}
        """


rule bam_downsampling_TSC_EXMC_primed:
    input:
        bam=WORKDIR+"bam/merged_downsampled_bam/{cell_type}_{target_mark}.hg38.dedupped.merged.bam",
        bai=WORKDIR+"bam/merged_downsampled_bam/{cell_type}_{target_mark}.hg38.dedupped.merged.bam.bai"
    output:
        bam_downsampled=WORKDIR+"bam/merged_downsampled_bam/{cell_type}_{target_mark}_downsampled.bam"
    log:
        "log/{cell_type}_{target_mark}_downsampling.log"
    threads: 6
    shell:
        """
        reads=26500000
        bam={input.bam}
        fraction=$(samtools idxstats -@ {threads} $bam | cut -f3 | awk -v ct=$reads 'BEGIN {{total=0}} {{total += $1}} END {{print ct/total}}')
        samtools view -@ {threads} -b -s ${{fraction}} $bam > {output.bam_downsampled} 2> {log}
        """


rule index_downsampled_CUTRUN:
    input:
        WORKDIR+"bam/merged_downsampled_bam/{cell_type}_{target_mark}_downsampled.bam"
    output:
        bai=WORKDIR+"bam/merged_downsampled_bam/{cell_type}_{target_mark}_downsampled.bam.bai"
    threads: 4
    shell:
        """
        samtools index -@ {threads} {input}
        """


rule idxstats_bam:
    input:
        bam=WORKDIR+"bam/merged_downsampled_bam/{cell_type}_{target_mark}_downsampled.bam",
        bai=WORKDIR+"bam/merged_downsampled_bam/{cell_type}_{target_mark}_downsampled.bam.bai"
    output: 
        WORKDIR+"idxstats/{cell_type}_{target_mark}_downsampled.idxstats.txt"
    log: 
        "log/{cell_type}_{target_mark}_downsampled.idxstats.err"
    shell:
        """
        samtools idxstats {input.bam} > {output} 2> {log}
        """

