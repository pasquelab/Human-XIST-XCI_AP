# Snakefile for raw data processing (fastq to bigwigs) of cutrun/chip data with mouse read filtering (for von-meyenn ChIPseq data downloaded from sra or Naive cutrun from Charbel) for Leo's Cut&Run project, started on 09/11/2023 

configfile: "config.json"

WORKDIR = config["WORKING_PATH"]

rule all:
    input:
        #reporting
        #fastqc_raw=expand(WORKDIR+"fastqc/raw/{sample}.R{r}_fastqc.html", sample=config["SAMPLES"], r=["1","2"]),
        fastqc_trimmed=expand(WORKDIR+"fastqc/trimmed/{sample}_trimmed_R{r}_fastqc.html", sample=config["SAMPLES"], r=["1","2"]),
        idxstats=expand(WORKDIR+"idxstats/{sample}_Filtered_idxstats.txt", sample=config["SAMPLES"]),
        #bigwigs
        bigwig_raw=expand(WORKDIR+"bigwig/raw/{sample}.raw.all.bw", sample=config["SAMPLES"]),
        bigwig_bpm=expand(WORKDIR+"bigwig/bpm/{sample}.BPM.all.bw", sample=config["SAMPLES"])



