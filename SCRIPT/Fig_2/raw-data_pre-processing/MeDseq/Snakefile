# READ FILTERING

rule qual_reads_human:
    input:
        bam=outdir_human+"/bam/{sample}.sorted.hg38.bam",
    output:
        temp(outdir_human+"/bam/{sample}.hg38.qual.bam")
    params: qual=10
    priority: 3
    log:
        "log/{sample}_hg38_qual.log"
    shell:
        "(samtools view -q {params.qual} -b {input.bam} > {output}) \
            2> {log}"


rule qual_reads_mus_human:
    input:
        bam=outdir_human+"/bam/{sample}.sorted.mus.bam",
    output:
        temp(outdir_human+"/bam/{sample}.mus.qual.bam")
    params: qual=10
    priority: 3
    log:
        "log/{sample}_mus_qual.log"
    shell:
        "(samtools view -q {params.qual} -b {input.bam} > {output}) \
            2> {log}"


rule samtools_index_hg38_human:
    input: outdir_human+"/bam/{sample}.hg38.qual.bam"
    output: temp(outdir_human+"/bam/{sample}.hg38.qual.bam.bai")
    params:
        "" # optional params string
    priority: 3
    threads: 6
    log: "log/{sample}_index.log"
    shell:"""
    samtools index -b -@ {threads} {input} 2> {log}
    """


rule samtools_index_mus_human:
    input: outdir_human+"/bam/{sample}.mus.qual.bam"
    output: temp(outdir_human+"/bam/{sample}.mus.qual.bam.bai")
    params:
        "" # optional params string
    priority: 3
    threads: 6
    log: "log/{sample}_index.log"
    shell:"""
    samtools index -b -@ {threads} {input} 2> {log}
    """


rule Perform_Xenofilter_human:
    input: 
        mouse_bam=outdir_human+"/bam/{sample}.mus.qual.bam",
        human_bam=outdir_human+"/bam/{sample}.hg38.qual.bam",
        mouse_bam_bai=outdir_human+"/bam/{sample}.mus.qual.bam.bai",
        human_bam_bai=outdir_human+"/bam/{sample}.hg38.qual.bam.bai"

    output:
        bam=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_Filtered.bam",
        bai=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_Filtered.bam.bai"
    log:"log/{sample}_xenofilter.log"
    shell:
        "(Rscript Xeno_human.R {input.human_bam} {input.mouse_bam}) 2> {log}"



# DOWNSAMPLING

rule bam_downsampling:
    input:
        bam=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_Filtered.bam",
        bai=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_Filtered.bam.bai"
    output:
        bam_downsampled=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_downsampled.bam"
    log:"log/{sample}_downsample.log"
    threads: 6
    shell:"""
    reads=1500000
    bam={input.bam}
    fraction=$(samtools idxstats -@ {threads} $bam | cut -f3 | awk -v ct=$reads 'BEGIN {{total=0}} {{total += $1}} END {{print ct/total}}')
    samtools view -@ {threads} -b -s ${{fraction}} $bam > {output.bam_downsampled} 2> {log}
    """


rule bam_downsampled_index:
    input: 
        bam_downsampled=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_downsampled.bam"
    output:
        bam_downsampled_bai=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_downsampled.bam.bai"
    threads: 6
    log: "log/{sample}_downsampled_index.log"
    shell:"""
    samtools index -b -@ {threads} {input.bam_downsampled} 2> {log}
    """



# BIGWIGs

rule bigwig_human:
    input:
        bam=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_downsampled.bam",
        bam_bai=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_downsampled.bam.bai"
    output: protected(outdir_human+"/bigwig/{sample}_bpm_no_dedduped_downsampled.bw")
    params:
        normalizeUsing="BPM",
        binSize=20,
        smoothLength=40
    log: "log/{sample}_BPM.log"
    shell:
        "(bamCoverage -b {input.bam} \
        --normalizeUsing {params.normalizeUsing}  --binSize {params.binSize} \
        --smoothLength {params.smoothLength} -o {output}) 2> {log}"


rule bigwig_human_no_norm:
    input:
        bam=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_downsampled.bam",
        bam_bai=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_downsampled.bam.bai"
    output: protected(outdir_human+"/bigwig/{sample}_no_norm_no_dedduped_downsampled.bw")
    params:
        normalizeUsing="None",
        binSize=20,
        smoothLength=40
    log: "log/{sample}_nor_norm.log"
    shell:
        "(bamCoverage -b {input.bam} \
        --normalizeUsing {params.normalizeUsing}  --binSize {params.binSize} \
        --smoothLength {params.smoothLength} -o {output}) 2> {log}"


rule bigwig_human_rpgc:
    input:
        bam=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_downsampled.bam",
        bam_bai=outdir_human+"/bam/{sample}/Filtered_bams/{sample}_downsampled.bam.bai"
    output: protected(outdir_human+"/bigwig/{sample}_rpgc_no_dedduped_downsampled.bw")
    params:
        normalizeUsing="RPGC",
        binSize=20,
        smoothLength=40
    log: "log/{sample}_rpgc.log"
    shell:
        "(bamCoverage -b {input.bam} \
        --normalizeUsing {params.normalizeUsing} \
        --effectiveGenomeSize 3209286105 \
        --binSize {params.binSize} \
        --smoothLength {params.smoothLength} -o {output}) 2> {log}"

