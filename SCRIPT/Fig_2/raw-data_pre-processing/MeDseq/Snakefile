configfile: "config.json"

outdir_human=config["output_path_human"]

human_gtf=config["human_gtf"]

rule all:
    input:
        bw_human_bpm_downsampled=expand(config["output_path_human"]+"/bigwig/{sample_human}_bpm_no_dedduped_downsampled.bw",sample_human=config["sample_human"]),
        bw_human_rpgc_downsampled=expand(config["output_path_human"]+"/bigwig/{sample_human}_rpgc_no_dedduped_downsampled.bw",sample_human=config["sample_human"]),
        bw_human_no_norm_downsampled=expand(config["output_path_human"]+"/bigwig/{sample_human}_no_norm_no_dedduped_downsampled.bw",sample_human=config["sample_human"])



# MAPPING ON MOUSE GENOME 

rule bowtie2_mus_human:
    input:
        sample=[outdir_human+"/fastq/trimmed/{sample}_trimmed.fq.gz"]
    output:
        temp(outdir_human+"/bam/{sample}.mus.bam")
    threads: 8
    resources:
        load=12
    params:
        index=config["bowtie2_index_mm10"],
        extra="--local --very-sensitive-local --no-unal --phred33 -L 10"
    log:
        "log/{sample}_bowtie2_mus.log"
    priority: 2
    shell:"""
    bowtie2 -x {params.index} -U {input.sample} {params.extra} --threads {threads} > {output}
    """


rule samtools_sort_mus_human:
    input:
        outdir_human+"/bam/{sample}.mus.bam"
    output:
        temp(outdir_human+"/bam/{sample}.sorted.mus.bam")
    threads: 8
    log:
        "log/{sample}_samtools_sort_mus.log"
    priority: 2
    shell:
        "(samtools sort -@ {threads} \
            -o {output} \
            {input}) 2> {log}"



